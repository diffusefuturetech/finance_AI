# LLM API (OpenAI-compatible endpoint)
LLM_API_BASE_URL=https://api.cloubic.com/v1
LLM_API_KEY=sk-xxxxx
LLM_MODEL=gpt-5.4

# Or Anthropic Claude API (alternative)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Feishu/Lark
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# Qlib data directory
QLIB_DATA_DIR=~/.qlib/qlib_data/cn_data_finance_ai

# Cache
CACHE_DB_PATH=~/.finance_ai/cache.db
